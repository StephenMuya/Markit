# ============================================================================
# NotionFlow Environment Configuration
# ============================================================================
# 
# This file contains ALL environment variables required to run NotionFlow.
# Copy this file to .env and update with your actual values.
#
# SECURITY WARNING: Never commit the .env file to version control!
# The .env file is already in .gitignore to prevent accidental commits.
#
# ============================================================================

# ============================================================================
# API KEYS & SECRETS
# ============================================================================

# Google Gemini API Key (REQUIRED)
# Used for AI-powered extraction of deal information from scraped articles.
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (REQUIRED for Audio Processing)
# Used by the MarkitAudioProcessor for Whisper transcription and GPT-4o extraction.
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database Connection (REQUIRED)
# These credentials are used by both the Python scraper and Java backend.
# 
# For local development with Docker Compose:
#   DB_HOST=localhost (or 'postgres' if running scraper in Docker)
#   DB_PORT=5432
#   DB_NAME=notionflow
#   DB_USER=postgres
#   DB_PASSWORD=<set a strong password>
#
# For production:
#   Use your cloud provider's database credentials
#   Enable SSL/TLS connections (see spring.datasource.url in application.properties)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=notionflow
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============================================================================
# JAVA BACKEND CONFIGURATION
# ============================================================================

# Server Configuration
# Port on which the Spring Boot backend will run
SERVER_PORT=8080

# Spring Boot Profile (Optional)
# Options: dev, prod, test
# Default: dev
# SPRING_PROFILES_ACTIVE=dev

# JPA/Hibernate Configuration
# Controls how Hibernate manages the database schema
# Options: validate, update, create, create-drop, none
# Recommended: update (for dev), validate (for prod)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# SQL Logging (Optional)
# Set to true to see SQL queries in logs (useful for debugging)
# Default: false (recommended for production)
SPRING_JPA_SHOW_SQL=false

# Logging Level (Optional)
# Options: TRACE, DEBUG, INFO, WARN, ERROR
# Default: INFO
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_NOTIONFLOW=DEBUG

# ============================================================================
# PYTHON SCRAPER CONFIGURATION
# ============================================================================

# Article Scraping Limit (Optional)
# Maximum number of articles to scrape per source
# Leave empty or set to 0 for unlimited scraping
# Recommended: 50-100 for testing, empty for production
MAX_ARTICLES_PER_SOURCE=

# Scraper User Agent (Optional)
# Custom user agent string for web scraping
# Default: Uses Playwright's default
# USER_AGENT=Mozilla/5.0 (compatible; NotionFlow/1.0)

# ============================================================================
# DOCKER CONFIGURATION (for docker-compose.yml)
# ============================================================================

# These variables are automatically used by docker-compose.yml
# If not set, docker-compose will use the defaults shown above

# POSTGRES_DB=${DB_NAME}
# POSTGRES_USER=${DB_USER}
# POSTGRES_PASSWORD=${DB_PASSWORD}

# ============================================================================
# DEPLOYMENT CONFIGURATION (for render.yaml)
# ============================================================================

# When deploying to Render or other cloud platforms, these variables
# are typically set through the platform's dashboard or CLI.
# The render.yaml file is configured to automatically use database
# credentials from the managed PostgreSQL service.

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and set your actual values (especially GEMINI_API_KEY and DB_PASSWORD)
# 3. Never commit .env to git (it's in .gitignore)
#
# Docker Compose:
# - docker-compose automatically reads .env file
# - Override values: docker-compose --env-file .env.prod up
#
# Manual Setup:
# - Source the file: source .env (Linux/Mac) or set variables in Windows
# - Or use a .env loader library in your application
#
# ============================================================================
