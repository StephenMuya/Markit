# NotionFlow Environment Variables

# Gemini API for deal extraction (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite database path (Optional, default: ./data/notionflow.db)
SQLITE_DB_PATH=./data/notionflow.db

# Maximum articles to scrape per source (Optional, default: unlimited)
# Set to a number like 10, 50, 100, or leave empty for unlimited
MAX_ARTICLES_PER_SOURCE=

# Legacy Notion configuration (no longer needed for SQLite version)
# NOTION_API_KEY=
# FIRMS_DB_ID=
# EQUITY_DB_ID=
