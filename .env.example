# NotionFlow Environment Variables

# Gemini API for deal extraction (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL Database Configuration (Required)
# IMPORTANT: Change these values for your environment, especially DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notionflow
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Maximum articles to scrape per source (Optional, default: unlimited)
# Set to a number like 10, 50, 100, or leave empty for unlimited
MAX_ARTICLES_PER_SOURCE=
